generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id              Int      @id @default(autoincrement())
  username        String   @unique
  name            String
  password        String
  customerNumber  String?
  address         String
  phone           String
  role            Role     @default(USER)
  reviews         Review[]
  submissions Food[] 
  createdAt       DateTime @default(now())

  @@map("users")
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String
  foods Food[]

  @@map("categories")
}

model Food {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Decimal
  image_url   String?
  avgRating   Decimal  @default(0)
  status      FoodStatus @default(PENDING)
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  Int
  submittedBy Int?
  submitter   User?    @relation(fields: [submittedBy], references: [id])
  reviews     Review[]

  @@map("foods")
}
enum FoodStatus {
  PENDING
  APPROVED
  REJECTED
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  food      Food     @relation(fields: [foodId], references: [id])
  foodId    Int
  createdAt DateTime @default(now())

  @@map("reviews")
}

enum Role {
  USER
  ADMIN
}

